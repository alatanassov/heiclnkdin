<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ISO/IEC 42001:2023 — Cryptographic Security & Post-Quantum Resilience</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;600;700&family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,600;0,700;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0e1a;
    --bg2: #0f1526;
    --bg3: #141d30;
    --bg4: #1a2540;
    --border: #1e3a5f;
    --border2: #2a4a6b;
    --accent-blue: #00d4ff;
    --accent-cyan: #00ffcc;
    --accent-gold: #ffd700;
    --accent-violet: #a78bfa;
    --accent-orange: #ff6b35;
    --accent-red: #ff4757;
    --accent-green: #00ff87;
    --text-primary: #e8f4fd;
    --text-secondary: #8ba8c8;
    --text-muted: #4a6080;
    --mono: 'IBM Plex Mono', monospace;
    --sans: 'IBM Plex Sans', sans-serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text-primary);
    font-family: var(--sans);
    line-height: 1.6;
    min-height: 100vh;
  }

  /* ─── HERO ─── */
  .hero {
    position: relative;
    padding: 80px 40px 60px;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 20% 0%, rgba(0,212,255,0.08) 0%, transparent 60%),
      radial-gradient(ellipse 60% 80% at 80% 100%, rgba(167,139,250,0.07) 0%, transparent 60%),
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 39px,
        rgba(30,58,95,0.25) 39px,
        rgba(30,58,95,0.25) 40px
      ),
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 59px,
        rgba(30,58,95,0.15) 59px,
        rgba(30,58,95,0.15) 60px
      );
    pointer-events: none;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(0,212,255,0.1);
    border: 1px solid rgba(0,212,255,0.3);
    border-radius: 3px;
    padding: 4px 12px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent-blue);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 28px;
  }

  .hero-badge .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent-blue);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .hero h1 {
    font-family: var(--mono);
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .hero h1 .std {
    color: var(--accent-blue);
  }

  .hero h1 .year {
    color: var(--text-muted);
    font-weight: 300;
    font-size: 0.65em;
  }

  .hero-sub {
    font-family: var(--mono);
    font-size: clamp(14px, 2vw, 20px);
    font-weight: 300;
    color: var(--accent-cyan);
    margin-bottom: 24px;
    letter-spacing: 0.04em;
  }

  .hero-desc {
    max-width: 720px;
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 36px;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--text-muted);
  }

  .hero-meta span { display: flex; align-items: center; gap: 6px; }
  .hero-meta span::before { content: '//'; color: var(--border2); }

  /* ─── TOC ─── */
  .toc-bar {
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
    padding: 0 40px;
    display: flex;
    overflow-x: auto;
    gap: 0;
    scrollbar-width: none;
  }

  .toc-bar::-webkit-scrollbar { display: none; }

  .toc-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 20px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-muted);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: all 0.2s;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .toc-item:hover {
    color: var(--accent-blue);
    border-bottom-color: var(--accent-blue);
    background: rgba(0,212,255,0.04);
  }

  .toc-num {
    color: var(--border2);
    font-size: 10px;
  }

  /* ─── MAIN LAYOUT ─── */
  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 40px;
  }

  section {
    margin-bottom: 80px;
  }

  /* ─── SECTION HEADERS ─── */
  .section-header {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 40px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }

  .section-num {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--accent-blue);
    letter-spacing: 0.1em;
    opacity: 0.7;
  }

  .section-title {
    font-family: var(--mono);
    font-size: clamp(20px, 3vw, 28px);
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .section-title .highlight {
    color: var(--accent-cyan);
  }

  /* ─── CALLOUT BOXES ─── */
  .callout {
    border-left: 3px solid var(--accent-blue);
    background: rgba(0,212,255,0.04);
    padding: 20px 24px;
    margin: 28px 0;
    border-radius: 0 4px 4px 0;
  }

  .callout.gold { border-color: var(--accent-gold); background: rgba(255,215,0,0.04); }
  .callout.violet { border-color: var(--accent-violet); background: rgba(167,139,250,0.04); }
  .callout.green { border-color: var(--accent-green); background: rgba(0,255,135,0.04); }
  .callout.orange { border-color: var(--accent-orange); background: rgba(255,107,53,0.04); }
  .callout.red { border-color: var(--accent-red); background: rgba(255,71,87,0.04); }

  .callout-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent-blue);
    margin-bottom: 8px;
    opacity: 0.8;
  }

  .callout.gold .callout-label { color: var(--accent-gold); }
  .callout.violet .callout-label { color: var(--accent-violet); }
  .callout.green .callout-label { color: var(--accent-green); }
  .callout.orange .callout-label { color: var(--accent-orange); }
  .callout.red .callout-label { color: var(--accent-red); }

  .callout p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.75;
  }

  .callout strong { color: var(--text-primary); font-weight: 600; }

  /* ─── PROSE ─── */
  .prose {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.85;
    max-width: 820px;
  }

  .prose strong { color: var(--text-primary); font-weight: 600; }
  .prose em { color: var(--accent-cyan); font-style: normal; font-family: var(--mono); font-size: 0.9em; }

  /* ─── GRID CARDS ─── */
  .grid-2 { display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 20px; }
  .grid-3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; }
  .grid-4 { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; }

  .card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 24px;
    position: relative;
    transition: border-color 0.2s;
  }

  .card:hover { border-color: var(--border2); }

  .card-accent {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--accent-blue);
  }

  .card-accent.gold { background: var(--accent-gold); }
  .card-accent.violet { background: var(--accent-violet); }
  .card-accent.cyan { background: var(--accent-cyan); }
  .card-accent.orange { background: var(--accent-orange); }
  .card-accent.red { background: var(--accent-red); }
  .card-accent.green { background: var(--accent-green); }

  .card-icon {
    font-size: 24px;
    margin-bottom: 12px;
  }

  .card-label {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .card h3 {
    font-family: var(--mono);
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 10px;
    letter-spacing: -0.01em;
  }

  .card p {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .card .tag {
    display: inline-block;
    margin-top: 10px;
    padding: 3px 8px;
    background: rgba(0,212,255,0.08);
    border: 1px solid rgba(0,212,255,0.2);
    border-radius: 2px;
    font-family: var(--mono);
    font-size: 10px;
    color: var(--accent-blue);
    letter-spacing: 0.08em;
  }

  /* ─── CLAUSE TABLE ─── */
  .clause-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13.5px;
    margin: 24px 0;
  }

  .clause-table th {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    background: var(--bg2);
    padding: 12px 16px;
    text-align: left;
    border-bottom: 1px solid var(--border);
    border-top: 1px solid var(--border);
  }

  .clause-table td {
    padding: 14px 16px;
    border-bottom: 1px solid rgba(30,58,95,0.4);
    color: var(--text-secondary);
    vertical-align: top;
    line-height: 1.65;
  }

  .clause-table tr:hover td { background: rgba(0,212,255,0.025); }

  .clause-table .clause-id {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--accent-blue);
    font-weight: 600;
    white-space: nowrap;
  }

  .clause-table .clause-name {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 13px;
  }

  .badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 2px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    font-weight: 600;
  }

  .badge-blue { background: rgba(0,212,255,0.12); color: var(--accent-blue); border: 1px solid rgba(0,212,255,0.25); }
  .badge-gold { background: rgba(255,215,0,0.1); color: var(--accent-gold); border: 1px solid rgba(255,215,0,0.25); }
  .badge-violet { background: rgba(167,139,250,0.1); color: var(--accent-violet); border: 1px solid rgba(167,139,250,0.25); }
  .badge-green { background: rgba(0,255,135,0.1); color: var(--accent-green); border: 1px solid rgba(0,255,135,0.25); }
  .badge-orange { background: rgba(255,107,53,0.1); color: var(--accent-orange); border: 1px solid rgba(255,107,53,0.25); }
  .badge-red { background: rgba(255,71,87,0.1); color: var(--accent-red); border: 1px solid rgba(255,71,87,0.25); }

  /* ─── RISK MATRIX ─── */
  .risk-visual {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3px;
    max-width: 420px;
    margin: 24px 0;
  }

  .risk-cell {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    border-radius: 2px;
    min-height: 90px;
  }

  .risk-cell .risk-title {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  .risk-cell p {
    font-size: 11px;
    color: rgba(255,255,255,0.6);
    line-height: 1.5;
  }

  /* ─── MILESTONE TIMELINE ─── */
  .timeline {
    position: relative;
    padding-left: 32px;
    margin: 28px 0;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 6px;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: linear-gradient(to bottom, var(--accent-blue), var(--accent-violet));
  }

  .timeline-item {
    position: relative;
    margin-bottom: 28px;
  }

  .timeline-item::before {
    content: '';
    position: absolute;
    left: -28px;
    top: 6px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent-blue);
    border: 2px solid var(--bg);
    box-shadow: 0 0 8px rgba(0,212,255,0.5);
  }

  .timeline-item.gold::before { background: var(--accent-gold); box-shadow: 0 0 8px rgba(255,215,0,0.5); }
  .timeline-item.violet::before { background: var(--accent-violet); box-shadow: 0 0 8px rgba(167,139,250,0.5); }
  .timeline-item.green::before { background: var(--accent-green); box-shadow: 0 0 8px rgba(0,255,135,0.5); }
  .timeline-item.orange::before { background: var(--accent-orange); box-shadow: 0 0 8px rgba(255,107,53,0.5); }

  .timeline-date {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent-blue);
    letter-spacing: 0.08em;
    margin-bottom: 4px;
  }

  .timeline-item.gold .timeline-date { color: var(--accent-gold); }
  .timeline-item.violet .timeline-date { color: var(--accent-violet); }
  .timeline-item.green .timeline-date { color: var(--accent-green); }
  .timeline-item.orange .timeline-date { color: var(--accent-orange); }

  .timeline-title {
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 4px;
  }

  .timeline-body {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* ─── CODE BLOCK ─── */
  .code-block {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    margin: 24px 0;
  }

  .code-block-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 16px;
    background: var(--bg3);
    border-bottom: 1px solid var(--border);
  }

  .code-block-title {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.08em;
  }

  .code-block-dots { display: flex; gap: 5px; }
  .code-block-dots span { width: 9px; height: 9px; border-radius: 50%; }
  .code-block-dots span:nth-child(1) { background: #ff5f56; }
  .code-block-dots span:nth-child(2) { background: #febc2e; }
  .code-block-dots span:nth-child(3) { background: #28c840; }

  .code-block pre {
    padding: 20px;
    font-family: var(--mono);
    font-size: 12px;
    line-height: 1.8;
    color: var(--text-secondary);
    overflow-x: auto;
  }

  .code-block .kw { color: var(--accent-violet); }
  .code-block .str { color: var(--accent-cyan); }
  .code-block .cmt { color: var(--text-muted); }
  .code-block .key { color: var(--accent-gold); }
  .code-block .val { color: var(--accent-green); }
  .code-block .cls { color: var(--accent-blue); }

  /* ─── ANNEX CONTROL GRID ─── */
  .control-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
    margin: 24px 0;
  }

  .control-item {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 14px 16px;
    position: relative;
    overflow: hidden;
  }

  .control-item::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--accent-blue);
  }

  .control-item.gold::before { background: var(--accent-gold); }
  .control-item.violet::before { background: var(--accent-violet); }
  .control-item.green::before { background: var(--accent-green); }
  .control-item.orange::before { background: var(--accent-orange); }
  .control-item.cyan::before { background: var(--accent-cyan); }

  .control-ref {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    margin-bottom: 4px;
  }

  .control-name {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 4px;
  }

  .control-desc {
    font-size: 11px;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* ─── COMPARISON TABLE ─── */
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
    margin: 24px 0;
  }

  .compare-table th {
    font-family: var(--mono);
    font-size: 11px;
    padding: 14px 16px;
    text-align: left;
    border-bottom: 2px solid var(--border);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .compare-table th:first-child { color: var(--text-muted); }
  .compare-table th:nth-child(2) { color: var(--accent-blue); }
  .compare-table th:nth-child(3) { color: var(--accent-cyan); }
  .compare-table th:nth-child(4) { color: var(--accent-gold); }

  .compare-table td {
    padding: 13px 16px;
    border-bottom: 1px solid rgba(30,58,95,0.4);
    color: var(--text-secondary);
    line-height: 1.6;
    vertical-align: top;
  }

  .compare-table td:first-child {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--text-primary);
    font-weight: 600;
  }

  .compare-table tr:hover td { background: rgba(0,212,255,0.02); }

  .check { color: var(--accent-green); font-size: 14px; }
  .partial { color: var(--accent-gold); font-size: 14px; }
  .cross { color: var(--accent-red); font-size: 14px; }

  /* ─── PQC ALGORITHM TABLE ─── */
  .algo-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 20px 22px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .algo-card .algo-fips {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--accent-blue);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .algo-card .algo-name {
    font-family: var(--mono);
    font-size: 15px;
    font-weight: 700;
    color: var(--text-primary);
  }

  .algo-card .algo-basis {
    font-size: 12px;
    color: var(--text-muted);
    font-family: var(--mono);
  }

  .algo-card .algo-purpose {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .algo-card .algo-42001 {
    margin-top: 6px;
    padding-top: 10px;
    border-top: 1px solid var(--border);
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .algo-card .algo-42001 strong {
    color: var(--accent-cyan);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 3px;
  }

  /* ─── MATURITY MODEL ─── */
  .maturity-track {
    display: flex;
    gap: 4px;
    margin: 28px 0;
    flex-wrap: wrap;
  }

  .maturity-level {
    flex: 1;
    min-width: 140px;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 18px 16px;
    position: relative;
  }

  .maturity-level::after {
    content: '→';
    position: absolute;
    right: -14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--border2);
    font-size: 16px;
    z-index: 1;
  }

  .maturity-level:last-child::after { display: none; }

  .maturity-num {
    font-family: var(--mono);
    font-size: 28px;
    font-weight: 700;
    color: var(--border2);
    margin-bottom: 6px;
  }

  .maturity-level.active .maturity-num { color: var(--accent-blue); }
  .maturity-level.target .maturity-num { color: var(--accent-gold); }

  .maturity-title {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .maturity-desc {
    font-size: 11px;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* ─── STAT BLOCKS ─── */
  .stat-row {
    display: grid;
